# Copia este archivo como .env y rellena los valores reales
# NUNCA subas .env a Git (ya está en .gitignore)

# Base de datos — local (dev) usa SQLite; producción usa PostgreSQL (Azure)
# Formato PostgreSQL: postgresql://usuario:contraseña@host:5432/nombre_db
DATABASE_URL=postgresql://rtsadmin:TuPassword@rts-postgres.postgres.database.azure.com:5432/rts_inventario

# Clave secreta para sesiones Flask
# Genera una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria

# Entorno
FLASK_ENV=production
