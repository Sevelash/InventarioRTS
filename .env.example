# Copia este archivo a .env y llena los valores reales
# NUNCA subas .env al repositorio

# Clave secreta de Flask (genera una aleatoria con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=cambia-esto-por-una-clave-aleatoria-larga

# Ruta de la base de datos (relativa a la carpeta instance/)
# Por defecto SQLite — para producción se puede cambiar a PostgreSQL:
# DATABASE_URL=postgresql://usuario:password@host:5432/rts_inventory
DATABASE_URL=sqlite:///rts_inventory.db

# Puerto (default 5050)
PORT=5050

# Modo debug (False en producción)
DEBUG=False
